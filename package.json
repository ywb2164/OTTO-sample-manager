{
  "name": "sample-manager",
  "version": "2.5.0",
  "description": "鬼畜采样管理工具",
  "author": "ywb2164",
  "license": "MIT",
  "homepage": "https://github.com/ywb2164/OTTO-sample-manager#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ywb2164/OTTO-sample-manager.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "test": "vitest run",
    "check:types": "tsc -p tsconfig.node.json --noEmit --tsBuildInfoFile node_modules/.cache/otto-node.tsbuildinfo && tsc -p tsconfig.web.json --noEmit --tsBuildInfoFile node_modules/.cache/otto-web.tsbuildinfo",
    "build": "electron-vite build",
    "pack": "npm run build && electron-builder --win --x64",
    "preview": "electron-vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:release": "tauri build --config src-tauri/tauri.release.conf.json",
    "tauri:renderer:dev": "vite --config vite.tauri.config.ts --host 127.0.0.1 --port 1420",
    "tauri:renderer:build": "vite build --config vite.tauri.config.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-opener": "2.5.0",
    "@tauri-apps/plugin-updater": "2.10.0",
    "@tanstack/react-virtual": "^3.0.1",
    "electron-store": "8.2.0",
    "electron-updater": "6.8.9",
    "lucide-react": "^1.14.0",
    "pinyin-pro": "^3.28.0",
    "uuid": "^13.0.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@testing-library/react": "^15.0.7",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "28.2.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "jsdom": "^24.1.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.6.1"
  }
}
